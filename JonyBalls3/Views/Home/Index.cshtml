@{
    ViewData["Title"] = "Главная";
}

<!-- HERO SECTION -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content">
                <h1 class="hero-title">
                    <span class="gradient-text">Управляй ремонтом</span>
                    <br>просто и эффективно
                </h1>
                <p class="hero-subtitle">
                    JonyBalls3 — комплексная платформа для управления ремонтными работами. От поиска подрядчиков до финальной отделки.
                </p>
                <div class="hero-buttons">
                    <a asp-controller="Projects" asp-action="Create" class="btn btn-gradient btn-lg">
                        <i class="fas fa-plus-circle me-2"></i>Создать проект
                    </a>
                    <a asp-controller="Calculator" asp-action="Index" class="btn btn-outline-gradient btn-lg">
                        <i class="fas fa-calculator me-2"></i>Рассчитать смету
                    </a>
                </div>

                <!-- STATS -->
                <div class="mt-5 pt-3">
                    <div class="row g-4">
                        <div class="col-6 col-md-4">
                            <div class="stat-card">
                                <div class="stat-number">500+</div>
                                <div class="stat-label">Проектов</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="stat-card">
                                <div class="stat-number">200+</div>
                                <div class="stat-label">Подрядчиков</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-4">
                            <div class="stat-card">
                                <div class="stat-number">98%</div>
                                <div class="stat-label">Довольных</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ANIMATION CONTAINER -->
            <div class="col-lg-6">
                <div class="animation-container">
                    <div class="room-before">
                        <div class="text-center">
                            <i class="fas fa-home"></i>
                            <div style="font-size: 0.8rem; margin-top: 1rem;">Пусто</div>
                        </div>
                    </div>
                    <div class="divider-line"></div>
                    <div class="room-after">
                        <div class="text-center">
                            <i class="fas fa-sparkles"></i>
                            <div style="font-size: 0.8rem; margin-top: 1rem;">Готово!</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURES SECTION -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">
                Почему выбирают <span class="text-gradient">JonyBalls3</span>
            </h2>
            <p class="lead text-muted">Все инструменты для успешного ремонта в одном месте</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-magic"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Простота использования</h4>
                    <p class="text-muted">Интуитивный интерфейс, понятный каждому. Не нужно быть профессионалом.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Полный контроль</h4>
                    <p class="text-muted">Отслеживайте бюджет, сроки и качество работ в реальном времени.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon">
                        <i class="fas fa-users"></i>
                    </div>
                    <h4 class="fw-bold mb-2">Проверенные подрядчики</h4>
                    <p class="text-muted">Только верифицированные специалисты с реальными отзывами.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- PROCESS SECTION -->
<section class="py-5 bg-white rounded-4 shadow-sm mx-3 mx-md-0 mb-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Как это работает</h2>
            <p class="lead text-muted">Всего 4 простых шага к идеальному ремонту</p>
        </div>

        <div class="row">
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="process-step" data-step="1">
                    <h5 class="process-title">Создайте проект</h5>
                    <p class="process-description">Укажите параметры помещения, тип ремонта и бюджет</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3 mb-4">
                <div class="process-step" data-step="2">
                    <h5 class="process-title">Рассчитайте смету</h5>
                    <p class="process-description">Используйте калькулятор для точного расчета стоимости</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3 mb-4">
                <div class="process-step" data-step="3">
                    <h5 class="process-title">Найдите подрядчика</h5>
                    <p class="process-description">Выберите из проверенных специалистов с отзывами</p>
                </div>
            </div>

            <div class="col-md-6 col-lg-3 mb-4">
                <div class="process-step" data-step="4">
                    <h5 class="process-title">Контролируйте процесс</h5>
                    <p class="process-description">Следите за выполнением и общайтесь с подрядчиком</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- TESTIMONIALS SECTION -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold mb-3">Что говорят клиенты</h2>
            <p class="lead text-muted">Реальные отзывы наших пользователей</p>
        </div>

        <div class="row g-4">
            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="testimonial-author">
                        <div class="testimonial-avatar">А</div>
                        <div>
                            <h6 class="mb-0 fw-bold">Алексей Петров</h6>
                            <small class="text-muted">Москва</small>
                        </div>
                    </div>
                    <p class="testimonial-text">"Отличный сервис! Помог найти хорошего мастера для ремонта кухни. Всё сделали качественно и в срок."</p>
                    <div class="testimonial-rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="testimonial-author">
                        <div class="testimonial-avatar" style="background: linear-gradient(135deg, #10b981, #059669);">Е</div>
                        <div>
                            <h6 class="mb-0 fw-bold">Елена Смирнова</h6>
                            <small class="text-muted">СПб</small>
                        </div>
                    </div>
                    <p class="testimonial-text">"Калькулятор сметы очень помог спланировать бюджет. Рекомендую всем, кто планирует ремонт!"</p>
                    <div class="testimonial-rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="testimonial-card">
                    <div class="testimonial-author">
                        <div class="testimonial-avatar" style="background: linear-gradient(135deg, #06b6d4, #0891b2);">Д</div>
                        <div>
                            <h6 class="mb-0 fw-bold">Дмитрий Иванов</h6>
                            <small class="text-muted">Казань</small>
                        </div>
                    </div>
                    <p class="testimonial-text">"Удобный интерфейс, всё понятно. Уже второй проект веду через JonyBalls3. Спасибо!"</p>
                    <div class="testimonial-rating">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="py-5 my-5">
    <div class="container">
        <div class="cta-section">
            <h2 class="cta-title">Готовы начать ремонт?</h2>
            <p class="cta-subtitle">Присоединяйтесь к тысячам довольных клиентов и начните управлять ремонтом прямо сейчас</p>
            <a asp-controller="Account" asp-action="Register" class="btn btn-light btn-lg rounded-pill px-5 py-3 fw-bold">
                <i class="fas fa-user-plus me-2"></i>Создать аккаунт бесплатно
            </a>
        </div>
    </div>
</section>

<style>
    /* Дополнительные стили для главной страницы */
    .hero-section {
        padding: 3rem 0;
    }
</style>

@section Styles {
    <style>
        @@media (max-width: 768px) {
            .animation-container {
                margin-top: 2rem;
            }
        }
    </style>
}
