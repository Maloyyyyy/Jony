@using System.Security.Claims
@model JonyBalls3.Models.Project
@{
    ViewData["Title"] = Model.Name;
    var isOwner = User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.UserId;
    var isContractor = Model.Contractor != null && User.FindFirstValue(ClaimTypes.NameIdentifier) == Model.Contractor.UserId;
    var canEdit = isOwner || isContractor;

    string GetStatusName(JonyBalls3.Models.ProjectStatus s) {
        switch(s) {
            case JonyBalls3.Models.ProjectStatus.Planning: return "Планирование";
            case JonyBalls3.Models.ProjectStatus.Active: return "Активный";
            case JonyBalls3.Models.ProjectStatus.Paused: return "Приостановлен";
            case JonyBalls3.Models.ProjectStatus.Completed: return "Завершён";
            case JonyBalls3.Models.ProjectStatus.Cancelled: return "Отменён";
            default: return s.ToString();
        }
    }
    string GetStatusBadge(JonyBalls3.Models.ProjectStatus s) {
        switch(s) {
            case JonyBalls3.Models.ProjectStatus.Completed: return "badge-success";
            case JonyBalls3.Models.ProjectStatus.Active: return "badge-info";
            case JonyBalls3.Models.ProjectStatus.Paused: return "badge-warning";
            case JonyBalls3.Models.ProjectStatus.Cancelled: return "badge-secondary";
            default: return "badge-warning";
        }
    }
    string GetStageName(JonyBalls3.Models.StageStatus s) {
        switch(s) {
            case JonyBalls3.Models.StageStatus.NotStarted: return "Не начат";
            case JonyBalls3.Models.StageStatus.InProgress: return "В работе";
            case JonyBalls3.Models.StageStatus.Completed: return "Завершён";
            case JonyBalls3.Models.StageStatus.Issues: return "Проблемы";
            default: return s.ToString();
        }
    }
    string GetStageBadge(JonyBalls3.Models.StageStatus s) {
        switch(s) {
            case JonyBalls3.Models.StageStatus.Completed: return "badge-success";
            case JonyBalls3.Models.StageStatus.InProgress: return "badge-info";
            case JonyBalls3.Models.StageStatus.Issues: return "badge-danger";
            default: return "badge-secondary";
        }
    }
    string GetContractorStatusName(JonyBalls3.Models.ContractorStatus s) {
        switch(s) {
            case JonyBalls3.Models.ContractorStatus.Available: return "Свободен";
            case JonyBalls3.Models.ContractorStatus.Busy: return "Занят";
            case JonyBalls3.Models.ContractorStatus.Unavailable: return "Недоступен";
            default: return s.ToString();
        }
    }
    string GetExpenseCategoryName(JonyBalls3.Models.ExpenseCategory c) {
        switch(c) {
            case JonyBalls3.Models.ExpenseCategory.Materials: return "Материалы";
            case JonyBalls3.Models.ExpenseCategory.Labor: return "Работы";
            case JonyBalls3.Models.ExpenseCategory.Tools: return "Инструменты";
            case JonyBalls3.Models.ExpenseCategory.Delivery: return "Доставка";
            case JonyBalls3.Models.ExpenseCategory.Other: return "Прочее";
            default: return c.ToString();
        }
    }
}
<style>
    .stage-card { cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; }
    .stage-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(0,0,0,0.1); }
    .photo-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 15px; }
    .photo-thumb { width: 100px; height: 100px; object-fit: cover; border-radius: 8px; border: 2px solid #e0e0e0; transition: transform 0.2s; }
    .photo-thumb:hover { transform: scale(1.05); border-color: #667eea; }
    .photo-item { display: flex; flex-direction: column; align-items: center; gap: 4px; max-width: 110px; }
    .photo-caption { font-size: 0.7rem; color: #64748b; text-align: center; word-break: break-word; max-width: 100px; }
</style>
<div class="container py-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="display-5 fw-bold" style="color: #667eea;">
                <i class="fas fa-project-diagram me-2"></i>@Model.Name
            </h1>
            <p class="lead text-muted">@Model.Description</p>
        </div>
        <div class="col-md-4 text-end d-flex flex-column align-items-end gap-2">
            <span class="badge @GetStatusBadge(Model.Status) fs-6">@GetStatusName(Model.Status)</span>
            @if (canEdit)
            {
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">
                        <i class="fas fa-edit me-1"></i>Редактировать
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">
                        <i class="fas fa-trash me-1"></i>Удалить
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card-modern card text-center">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Площадь</h6>
                    <h3 class="fw-bold text-primary mb-0">@Model.Area м²</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-modern card text-center">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Бюджет</h6>
                    <h3 class="fw-bold text-success mb-0">@Model.Budget.ToString("N0") ₽</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-modern card text-center">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Потрачено</h6>
                    <h3 class="fw-bold text-warning mb-0">@Model.Spent.ToString("N0") ₽</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-modern card text-center">
                <div class="card-body">
                    <h6 class="text-muted mb-2">Осталось</h6>
                    <h3 class="fw-bold @(Model.Remaining < 0 ? "text-danger" : "text-info") mb-0">@Model.Remaining.ToString("N0") ₽</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-lg border-0 rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="mb-3"><i class="fas fa-chart-line me-2" style="color: #667eea;"></i>Общий прогресс</h5>
            <div class="progress mb-2" style="height: 25px;">
                <div class="progress-bar bg-success progress-bar-striped" role="progressbar" style="width: @Model.Progress%;">@Model.Progress%</div>
            </div>
            <div class="row mt-3 small text-muted">
                <div class="col-md-6"><i class="fas fa-calendar-alt me-1"></i>Начало: @(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("dd.MM.yyyy") : "Не указано")</div>
                <div class="col-md-6 text-md-end"><i class="fas fa-calendar-check me-1"></i>Окончание: @(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd.MM.yyyy") : "Не указано")</div>
            </div>
        </div>
    </div>

    @if (Model.Contractor != null)
    {
        <div class="card shadow-lg border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-2"><i class="fas fa-user-tie me-2" style="color: #667eea;"></i>Подрядчик</h5>
                        <p class="mb-1 fw-bold">@Model.Contractor.CompanyName</p>
                        <p class="text-muted mb-0">@Model.Contractor.Specialization</p>
                    </div>
                    <div>
                        <span class="badge @(Model.Contractor.Status == JonyBalls3.Models.ContractorStatus.Available ? "badge-success" : Model.Contractor.Status == JonyBalls3.Models.ContractorStatus.Busy ? "badge-warning" : "badge-secondary") me-2">
                            @GetContractorStatusName(Model.Contractor.Status)
                        </span>
                        <a asp-controller="Chat" asp-action="Project" asp-route-id="@Model.Id" class="btn btn-sm btn-gradient">
                            <i class="fas fa-comment me-1"></i>Чат
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (isOwner)
    {
        <div class="card shadow-lg border-0 rounded-4 mb-4">
            <div class="card-body p-4 text-center">
                <i class="fas fa-user-plus fa-3x text-muted mb-3"></i>
                <h5>Нет подрядчика</h5>
                <p class="text-muted mb-3">Наймите подрядчика для выполнения работ</p>
                <a asp-action="FindContractor" asp-route-id="@Model.Id" class="btn btn-gradient">
                    <i class="fas fa-search me-2"></i>Найти подрядчика
                </a>
            </div>
        </div>
    }

    <div class="card shadow-lg border-0 rounded-4 mb-4">
        <div class="card-header bg-white border-0 pt-4 px-4">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="fas fa-list me-2" style="color: #667eea;"></i>Этапы работ</h5>
                @if (canEdit)
                {
                    <button class="btn btn-sm btn-outline-gradient" data-bs-toggle="modal" data-bs-target="#addStageModal">
                        <i class="fas fa-plus me-1"></i>Добавить этап
                    </button>
                }
            </div>
        </div>
        <div class="card-body p-4">
            @if (!Model.Stages.Any())
            {
                <p class="text-muted text-center mb-0">Нет этапов работ</p>
            }
            else
            {
                <div class="row g-3">
                    @foreach (var stage in Model.Stages.OrderBy(s => s.Order))
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card stage-card border-0 shadow-sm h-100" onclick="loadStageDetails(@stage.Id)">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <h6 class="fw-bold mb-0">@stage.Name</h6>
                                        <span class="badge @GetStageBadge(stage.Status)">@GetStageName(stage.Status)</span>
                                    </div>
                                    <p class="small text-muted mb-2">@(stage.Description?.Length > 50 ? stage.Description.Substring(0, 50) + "..." : stage.Description)</p>
                                    <div class="row small">
                                        <div class="col-6 text-muted">Бюджет:</div>
                                        <div class="col-6 fw-bold text-end">@stage.Budget.ToString("N0") ₽</div>
                                        <div class="col-6 text-muted">Потрачено:</div>
                                        <div class="col-6 fw-bold text-end">@stage.Spent.ToString("N0") ₽</div>
                                    </div>
                                    <div class="progress mt-2" style="height: 5px;">
                                        <div class="progress-bar bg-success" style="width: @stage.Progress%;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="mb-3"><i class="fas fa-chart-pie me-2" style="color: #667eea;"></i>Распределение бюджета</h5>
                    <canvas id="budgetChart" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="mb-3"><i class="fas fa-tasks me-2" style="color: #667eea;"></i>Прогресс по этапам</h5>
                    <canvas id="progressChart" style="max-height: 250px;"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Модальные окна -->
<div class="modal fade" id="stageDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content rounded-4">
            <div id="stageModalBody"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="addStageModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content rounded-4">
            <div class="modal-header">
                <h5 class="modal-title">Добавить этап</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addStageForm">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">Название этапа</label>
                        <input type="text" name="name" id="stageName" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание</label>
                        <textarea name="description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Бюджет (₽)</label>
                        <input type="number" name="budget" id="stageBudget" class="form-control" value="0" min="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Отмена</button>
                    <button type="submit" class="btn btn-primary">Добавить</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var stageModal, addStageModal;
        $(document).ready(function() {
            stageModal = new bootstrap.Modal(document.getElementById('stageDetailsModal'));
            addStageModal = new bootstrap.Modal(document.getElementById('addStageModal'));

            $('#addStageForm').submit(function(e) {
                e.preventDefault();
                var name = $('#stageName').val().trim();
                var budget = parseFloat($('#stageBudget').val()) || 0;
                if (!name) { toastr.error('Введите название этапа'); return; }
                if (budget < 0) { toastr.error('Бюджет не может быть отрицательным'); return; }
                
                $.post('@Url.Action("AddStage", "Projects")', $(this).serialize())
                    .done(function(res) {
                        if (res.success) { toastr.success('Этап добавлен'); addStageModal.hide(); setTimeout(() => location.reload(), 1000); }
                        else { toastr.error(res.message || 'Ошибка'); }
                    });
            });

            @if (Model.Stages.Any())
            {
                var stageNames = string.Join(",", Model.Stages.Select(s => $"'{s.Name.Replace("'", "\\'")}'"));
                var stageBudgets = string.Join(",", Model.Stages.Select(s => s.Budget));
                var stageProgress = string.Join(",", Model.Stages.Select(s => s.Progress));
                <text>
                var bCtx = document.getElementById('budgetChart');
                if (bCtx) {
                    new Chart(bCtx.getContext('2d'), {
                        type: 'doughnut',
                        data: { labels: [@Html.Raw(stageNames)], datasets: [{ data: [@Html.Raw(stageBudgets)], backgroundColor: ['#667eea','#764ba2','#f093fb','#4facfe','#43e97b','#fa709a'] }] },
                        options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
                    });
                }
                var pCtx = document.getElementById('progressChart');
                if (pCtx) {
                    new Chart(pCtx.getContext('2d'), {
                        type: 'bar',
                        data: { labels: [@Html.Raw(stageNames)], datasets: [{ label: 'Прогресс (%)', data: [@Html.Raw(stageProgress)], backgroundColor: '#667eea' }] },
                        options: { responsive: true, scales: { y: { beginAtZero: true, max: 100 } } }
                    });
                }
                </text>
            }
        });

        function loadStageDetails(id) {
            $('#stageModalBody').html('<div class="text-center py-4"><div class="spinner-border text-primary"></div></div>');
            stageModal.show();
            $.get('/ProjectStage/Details/' + id, function(data) { $('#stageModalBody').html(data); });
        }
    </script>
}
