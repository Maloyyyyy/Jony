@using System.Security.Claims
@model List<JonyBalls3.Models.ChatMessage>
@{
    ViewData["Title"] = "Чат";
    var project = ViewBag.Project as JonyBalls3.Models.Project;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var otherUser = project!.UserId == currentUserId ? project.Contractor?.User : project.User;
}

<style>
    .chat-wrapper {
        height: calc(100vh - 140px);
        min-height: 500px;
        display: flex;
        flex-direction: column;
    }
    .chat-header {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-radius: 12px 12px 0 0;
        padding: 16px 20px;
        flex-shrink: 0;
    }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        background: #f8f9fa;
        scroll-behavior: smooth;
    }
    .chat-footer {
        background: white;
        border-top: 1px solid #e0e0e0;
        padding: 12px 16px;
        border-radius: 0 0 12px 12px;
        flex-shrink: 0;
    }
    .msg-bubble {
        max-width: 70%;
        padding: 10px 14px;
        border-radius: 18px;
        margin-bottom: 4px;
        word-break: break-word;
        overflow-wrap: break-word;
        white-space: pre-wrap;
        position: relative;
    }
    .msg-mine {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border-bottom-right-radius: 4px;
        margin-left: auto;
    }
    .msg-other {
        background: white;
        color: #333;
        border-bottom-left-radius: 4px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    }
    .msg-time { font-size: 11px; opacity: 0.7; margin-top: 2px; }
    .msg-system { text-align: center; color: #888; font-size: 13px; margin: 12px 0; font-style: italic; }
    .typing-indicator { padding: 8px 14px; background: white; border-radius: 18px; border-bottom-left-radius: 4px; box-shadow: 0 1px 4px rgba(0,0,0,0.08); max-width: 80px; }
    .typing-dot { width: 7px; height: 7px; background: #aaa; border-radius: 50%; display: inline-block; animation: typing 1.2s infinite; }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }
    @@keyframes typing { 0%, 60%, 100% { transform: translateY(0); } 30% { transform: translateY(-6px); } }
    #messageInput:focus { box-shadow: none; border-color: #667eea; }
    .send-btn { background: linear-gradient(135deg, #667eea, #764ba2); border: none; border-radius: 50%; width: 44px; height: 44px; display: flex; align-items: center; justify-content: center; color: white; flex-shrink: 0; transition: transform 0.1s; }
    .send-btn:hover { transform: scale(1.05); }
    .avatar-circle { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.2); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
</style>

<div class="chat-wrapper card border-0 shadow-lg rounded-3">
    <div class="chat-header">
        <div class="d-flex align-items-center gap-3">
            <a href="/Chat" class="btn btn-sm text-white border-white border-opacity-50 me-1">
                <i class="fas fa-arrow-left"></i>
            </a>
            <div class="avatar-circle">
                @if (otherUser?.AvatarUrl != null && otherUser.AvatarUrl != "")
                {
                    <img src="@otherUser.AvatarUrl" class="rounded-circle" width="40" height="40" style="object-fit:cover;">
                }
                else
                {
                    <i class="fas fa-user"></i>
                }
            </div>
            <div>
                <div class="fw-bold">@(otherUser?.FullName ?? otherUser?.UserName ?? "Пользователь")</div>
                <div style="font-size: 13px; opacity: 0.85;"><i class="fas fa-project-diagram me-1"></i>@project.Name</div>
            </div>
            <div class="ms-auto">
                <a href="/Projects/Details/@project.Id" class="btn btn-sm text-white border-white border-opacity-50">
                    <i class="fas fa-external-link-alt me-1"></i>Проект
                </a>
            </div>
        </div>
    </div>

    <div class="chat-messages" id="messagesContainer">
        @foreach (var msg in Model)
        {
            if (string.IsNullOrEmpty(msg.SenderId) || string.IsNullOrEmpty(msg.ReceiverId))
            {
                <div class="msg-system">@msg.Message</div>
            }
            else
            {
                var isMine = msg.SenderId == currentUserId;
                <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") mb-2" data-msg-id="@msg.Id">
                    <div>
                        <div class="msg-bubble @(isMine ? "msg-mine" : "msg-other")">@msg.Message</div>
                        <div class="d-flex @(isMine ? "justify-content-end" : "justify-content-start") align-items-center gap-1">
                            <span class="msg-time text-muted">@msg.SentAt.ToString("HH:mm")</span>
                            @if (isMine)
                            {
                                if (msg.IsRead)
                                {
                                    <span style="font-size:11px;"><i class="fas fa-check-double" style="color:#667eea;opacity:0.7;"></i></span>
                                }
                                else
                                {
                                    <span style="font-size:11px;opacity:0.5;"><i class="fas fa-check text-muted"></i></span>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
        <div class="d-flex justify-content-start mb-2" id="typingIndicator" style="display:none!important;">
            <div class="typing-indicator">
                <span class="typing-dot"></span><span class="typing-dot"></span><span class="typing-dot"></span>
            </div>
        </div>
    </div>

    <div class="chat-footer">
        <form id="messageForm" class="d-flex align-items-center gap-2">
            <input type="text" id="messageInput" class="form-control rounded-pill" placeholder="Написать сообщение..." autocomplete="off" maxlength="2000">
            <button type="submit" class="send-btn" id="sendBtn"><i class="fas fa-paper-plane"></i></button>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const projectId = @project.Id;
    const currentUserId = '@currentUserId';
    const container = document.getElementById('messagesContainer');
    let lastMessageId = @(Model.Any() ? Model.Max(m => m.Id) : 0);
    let isSending = false;

    function scrollToBottom(smooth) {
        container.scrollTo({ top: container.scrollHeight, behavior: smooth ? 'smooth' : 'auto' });
    }

    function formatTime(dateStr) {
        var d = new Date(dateStr);
        return d.getHours().toString().padStart(2,'0') + ':' + d.getMinutes().toString().padStart(2,'0');
    }

    function escHtml(str) {
        return str ? str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;') : '';
    }

    function appendMessage(msg) {
        var isMine = msg.isMine !== undefined ? msg.isMine : (msg.senderId === currentUserId);
        var isSystem = !msg.senderId;
        var div = document.createElement('div');
        if (isSystem) {
            div.className = 'msg-system';
            div.textContent = msg.message || msg.text || '';
        } else {
            div.className = 'd-flex ' + (isMine ? 'justify-content-end' : 'justify-content-start') + ' mb-2';
            div.setAttribute('data-msg-id', msg.id);
            var readIcon = isMine ? '<span style="font-size:11px;opacity:0.5;"><i class="fas fa-check text-muted"></i></span>' : '';
            div.innerHTML =
                '<div>' +
                    '<div class="msg-bubble ' + (isMine ? 'msg-mine' : 'msg-other') + '">' + escHtml(msg.message || msg.text || '') + '</div>' +
                    '<div class="d-flex ' + (isMine ? 'justify-content-end' : 'justify-content-start') + ' align-items-center gap-1">' +
                        '<span class="msg-time text-muted">' + formatTime(msg.sentAt) + '</span>' +
                        readIcon +
                    '</div>' +
                '</div>';
        }
        var typing = document.getElementById('typingIndicator');
        container.insertBefore(div, typing);
    }

    function pollMessages() {
        fetch('/Chat/GetMessages?projectId=' + projectId + '&lastMessageId=' + lastMessageId)
            .then(r => r.json())
            .then(messages => {
                if (messages && messages.length > 0) {
                    var wasAtBottom = container.scrollHeight - container.scrollTop - container.clientHeight < 80;
                    messages.forEach(function(msg) {
                        if (!document.querySelector('[data-msg-id="' + msg.Id + '"]')) {
                            appendMessage({ id: msg.Id, message: msg.Message, senderId: msg.SenderId, sentAt: msg.SentAt, isMine: msg.IsMine });
                        }
                        if (msg.Id > lastMessageId) lastMessageId = msg.Id;
                    });
                    if (wasAtBottom) scrollToBottom(true);
                }
            }).catch(function(){});
    }

    document.getElementById('messageForm').addEventListener('submit', function(e) {
        e.preventDefault();
        if (isSending) return;
        var input = document.getElementById('messageInput');
        var text = input.value.trim();
        if (!text) return;
        isSending = true;
        input.value = '';
        document.getElementById('sendBtn').disabled = true;
        fetch('/Chat/SendMessage', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ projectId: projectId, message: text })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success && data.message) {
                var msg = data.message;
                appendMessage({ id: msg.id, message: msg.text, senderId: msg.senderId, sentAt: msg.sentAt, isMine: true });
                if (msg.id > lastMessageId) lastMessageId = msg.id;
                scrollToBottom(true);
            }
        })
        .catch(function() { toastr.error('Ошибка отправки'); })
        .finally(function() {
            isSending = false;
            document.getElementById('sendBtn').disabled = false;
            input.focus();
        });
    });

    document.getElementById('messageInput').addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            document.getElementById('messageForm').dispatchEvent(new Event('submit'));
        }
    });

    scrollToBottom(false);
    setInterval(pollMessages, 3000);
</script>
}
