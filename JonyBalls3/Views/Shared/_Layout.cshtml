@using System.Security.Claims
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Jony</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modern-design.css" asp-append-version="true" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @await RenderSectionAsync("Styles", required: false)
    <style>
        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; display: flex; flex-direction: column; min-height: 100vh; }
        main { flex: 1; }
        .navbar { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(0,0,0,0.05); }
        .btn-gradient { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none; }
        .btn-gradient:hover { background: linear-gradient(135deg, #764ba2 0%, #667eea 100%); color: white; transform: translateY(-1px); }
        .site-footer { background: #fff; border-top: 1px solid rgba(0,0,0,0.05); padding: 1.5rem 0; margin-top: auto; }
        .notification-item-dd { padding: 10px 15px; border-bottom: 1px solid #f1f5f9; transition: background 0.2s; }
        .notification-item-dd:hover { background: #f8fafc; }
        .notification-item-dd.unread { background: #eff6ff; border-left: 3px solid #3b82f6; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light mb-3 shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-size: 1.5rem;">
                    <i class="fas fa-hammer me-2"></i>Jony
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Home" asp-action="Index">Главная</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Projects" asp-action="Index">Мои проекты</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Calculator" asp-action="Index">Калькулятор</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-controller="Contractors" asp-action="Index">Подрядчики</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav gap-2">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <!-- Уведомления -->
                            <li class="nav-item dropdown me-2">
                                <a class="nav-link position-relative" href="#" id="notifDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-bell fs-5 text-muted"></i>
                                    <span id="notifBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display:none; font-size: 0.65rem;">0</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 p-0" aria-labelledby="notifDropdown" style="width: 320px; max-height: 450px; overflow-y: auto;">
                                    <div class="p-3 border-bottom d-flex justify-content-between align-items-center bg-light rounded-top-4">
                                        <h6 class="mb-0 fw-bold">Уведомления</h6>
                                        <button id="markAllReadBtn" class="btn btn-sm btn-link p-0 text-decoration-none small">Прочитать все</button>
                                    </div>
                                    <div id="notifList">
                                        <div class="text-center py-4"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                                    </div>
                                    <a href="/Notifications" class="dropdown-item text-center py-2 small text-primary border-top">Показать все</a>
                                </div>
                            </li>

                            <!-- Чат -->
                            <li class="nav-item me-2">
                                <a class="nav-link position-relative" asp-controller="Chat" asp-action="Index">
                                    <i class="fas fa-comment-dots fs-5 text-muted"></i>
                                    <span id="chatBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary" style="display:none; font-size: 0.65rem;">0</span>
                                </a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:32px;height:32px;border:1px solid #e2e8f0;">
                                        <i class="fas fa-user text-primary" style="font-size:0.9rem;"></i>
                                    </div>
                                    <span class="fw-semibold">@(User.Identity?.Name ?? "Гость")</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item py-2" asp-controller="Profile" asp-action="Index"><i class="fas fa-id-card me-2 text-muted"></i>Мой профиль</a></li>
                                    <li><a class="dropdown-item py-2" asp-controller="Projects" asp-action="Index"><i class="fas fa-project-diagram me-2 text-muted"></i>Мои проекты</a></li>
                                    
                                    @if (User.IsInRole("Contractor"))
                                    {
                                        <li><a class="dropdown-item py-2" asp-controller="Contractors" asp-action="MyProfile"><i class="fas fa-tools me-2 text-muted"></i>Кабинет подрядчика</a></li>
                                    }
                                    else
                                    {
                                        <li><a class="dropdown-item py-2 text-primary fw-bold" asp-controller="Account" asp-action="BecomeContractor"><i class="fas fa-user-plus me-2"></i>Стать подрядчиком</a></li>
                                    }

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item py-2 text-danger fw-bold" asp-controller="Admin" asp-action="Index"><i class="fas fa-user-shield me-2"></i>Панель администратора</a></li>
                                    }

                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="px-3 py-1">
                                            <button type="submit" class="btn btn-sm btn-outline-danger w-100 rounded-pill">
                                                <i class="fas fa-sign-out-alt me-1"></i>Выход
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Account" asp-action="Login">Вход</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-gradient rounded-pill px-4" asp-controller="Account" asp-action="Register">Регистрация</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 text-muted small">
                <div class="d-flex align-items-center gap-2">
                    <span class="fw-bold" style="color: #667eea;">Jony</span>
                    <span>&mdash; платформа для управления ремонтом</span>
                </div>
                <div class="d-flex gap-3">
                    <a href="/" class="text-decoration-none text-muted">Главная</a>
                    <a href="/Projects" class="text-decoration-none text-muted">Проекты</a>
                    <a href="/Calculator" class="text-decoration-none text-muted">Калькулятор</a>
                    <a href="/Contractors" class="text-decoration-none text-muted">Подрядчики</a>
                </div>
                <div>
                    &copy; 2026 Jony. Все права защищены.
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: 'toast-top-right',
            timeOut: 4000,
            preventDuplicates: true
        };

        window.alert = function(msg) { toastr.info(msg); };
        window.confirm = function(msg) { return true; };

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <text>
            var _prevNotifCount = -1;
            function updateChatBadge() {
                $.get('/Chat/GetUnreadCount').done(function(data) {
                    var count = data.count || 0;
                    if (count > 0) { $('#chatBadge').text(count > 99 ? '99+' : count).show(); }
                    else { $('#chatBadge').hide(); }
                });
            }
            function updateInvitationBadge() {
                $.get('/Invitations/GetUnreadCount').done(function(count) {
                    if (count > 0) { $('#invitationBadge').text(count).show(); }
                    else { $('#invitationBadge').hide(); }
                });
            }
            function getNotifIcon(typeName) {
                var icons = {
                    'success':    '<i class="fas fa-check-circle" style="color: #10b981;"></i>',
                    'warning':    '<i class="fas fa-exclamation-triangle" style="color: #f59e0b;"></i>',
                    'danger':     '<i class="fas fa-times-circle" style="color: #ef4444;"></i>',
                    'chat':       '<i class="fas fa-comments" style="color: #06b6d4;"></i>',
                    'invitation': '<i class="fas fa-envelope" style="color: #667eea;"></i>',
                    'project':    '<i class="fas fa-project-diagram" style="color: #764ba2;"></i>',
                    'info':       '<i class="fas fa-info-circle" style="color: #6c757d;"></i>'
                };
                return icons[typeName] || icons['info'];
            }
            function escHtml(str) {
                if (!str) return '';
                var gt = String.fromCharCode(62), lt = String.fromCharCode(60), amp = '&';
                return str.split(amp).join(amp + 'amp;').split(lt).join(amp + 'lt;').split(gt).join(amp + 'gt;');
            }
            function loadRecentNotifications(showToast) {
                $.get('/Notifications/GetRecent').done(function(notifications) {
                    var list = $('#notifList');
                    if (!notifications || notifications.length === 0) {
                        list.html('<div class="text-center text-muted py-3 px-3"><i class="fas fa-bell-slash fa-2x mb-2 d-block"></i>Нет новых уведомлений</div>');
                        return;
                    }
                    var html = '';
                    notifications.forEach(function(n, idx) {
                        var unreadClass = !n.isRead ? 'unread' : '';
                        var link = n.link ? 'href="' + n.link + '"' : 'href="#"';
                        html += '<a ' + link + ' class="d-block text-decoration-none text-dark notification-item-dd ' + unreadClass + '" onclick="markNotifRead(' + n.id + ', this, event)">' +
                            '<div class="d-flex align-items-start gap-2">' +
                                '<div class="mt-1">' + getNotifIcon(n.typeName) + '</div>' +
                                '<div class="flex-grow-1">' +
                                    '<div class="fw-semibold small">' + escHtml(n.title) + '</div>' +
                                    '<div class="text-muted small">' + escHtml(n.message) + '</div>' +
                                    '<div class="text-muted" style="font-size:11px;">' + (n.timeAgo || '') + '</div>' +
                                '</div>' +
                                (!n.isRead ? '<span class="badge bg-primary rounded-pill align-self-center" style="font-size:9px;">Новое</span>' : '') +
                            '</div>' +
                        '</a>';
                        if (showToast && idx === 0 && !n.isRead) {
                            setTimeout(function() { toastr.info(n.message, n.title, { timeOut: 5000 }); }, 300);
                        }
                    });
                    list.html(html);
                });
            }
            function updateNotifications() {
                $.get('/Notifications/GetUnreadCount').done(function(data) {
                    var count = data.count || 0;
                    if (count > 0) { $('#notifBadge').text(count > 99 ? '99+' : count).show(); }
                    else { $('#notifBadge').hide(); }
                    if (count > _prevNotifCount && _prevNotifCount >= 0) {
                        loadRecentNotifications(true);
                    }
                    _prevNotifCount = count;
                });
            }
            function markNotifRead(id, el, event) {
                $.post('/Notifications/MarkAsRead/' + id);
                $(el).removeClass('unread').find('.badge.bg-primary').remove();
            }
            $('#markAllReadBtn').click(function(e) {
                e.preventDefault();
                e.stopPropagation();
                $.post('/Notifications/MarkAllAsRead', function(res) {
                    if (res.success) {
                        $('#notifBadge').hide();
                        _prevNotifCount = 0;
                        loadRecentNotifications(false);
                        toastr.success('Все уведомления прочитаны');
                    }
                });
            });
            $('#notifDropdown').on('show.bs.dropdown', function() {
                loadRecentNotifications(false);
            });
            setInterval(updateChatBadge, 5000);
            setInterval(updateInvitationBadge, 5000);
            setInterval(updateNotifications, 8000);
            updateChatBadge();
            updateInvitationBadge();
            updateNotifications();
            </text>
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
