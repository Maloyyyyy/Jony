<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - JonyBalls3</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="fas fa-tools me-2" style="color: #667eea;"></i>JonyBalls3
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="fas fa-home me-1"></i>Главная
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Projects" asp-action="Index">
                            <i class="fas fa-project-diagram me-1"></i>Проекты
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Calculator" asp-action="Index">
                            <i class="fas fa-calculator me-1"></i>Калькулятор
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Contractors" asp-action="Index">
                            <i class="fas fa-users me-1"></i>Подрядчики
                        </a>
                    </li>
                    
                    @* ЧАТ В НАВИГАЦИИ *@
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Chat" asp-action="Index">
                                <i class="fas fa-comments me-1"></i>Чаты
                                <span class="badge bg-danger" id="chatBadge" style="display:none;">0</span>
                            </a>
                        </li>
                    }
                    
                    @* ПРОФИЛЬ И ВХОД *@
                    @if (User.Identity.IsAuthenticated)
                    {
                        var isContractor = ViewBag.IsContractor ?? false;
                        
                        @if (!isContractor)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning" asp-controller="Account" asp-action="BecomeContractor">
                                    <i class="fas fa-hard-hat me-1"></i>Стать подрядчиком
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Invitations" asp-action="Index">
                                    <i class="fas fa-envelope me-1"></i>Запросы
                                    <span class="badge bg-danger" id="invitationBadge" style="display:none;">0</span>
                                </a>
                            </li>
                        }
                        
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle me-1"></i>@User.Identity.Name
                                @if (isContractor)
                                {
                                    <span class="badge bg-warning text-dark ms-1">Подрядчик</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Profile" asp-action="Index"><i class="fas fa-user me-2"></i>Мой профиль</a></li>
                                @if (isContractor)
                                {
                                    <li><a class="dropdown-item" asp-controller="Contractors" asp-action="MyProfile"><i class="fas fa-id-card me-2"></i>Профиль подрядчика</a></li>
                                }
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item">
                                            <i class="fas fa-sign-out-alt me-2"></i>Выйти
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-controller="Account" asp-action="Login">
                                <i class="fas fa-sign-in-alt me-2"></i>Войти
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    
    <script>
        toastr.options = {
            "closeButton": true,
            "progressBar": true,
            "positionClass": "toast-top-right"
        };

        function updateChatBadge() {
            $.get('/Chat/GetUnreadCount')
                .done(function(count) {
                    if (count > 0) {
                        $('#chatBadge').text(count).show();
                    } else {
                        $('#chatBadge').hide();
                    }
                });
        }
        
        function updateInvitationBadge() {
            $.get('/Invitations/GetPendingCount')
                .done(function(count) {
                    if (count > 0) {
                        $('#invitationBadge').text(count).show();
                    } else {
                        $('#invitationBadge').hide();
                    }
                });
        }
        
        @if (User.Identity.IsAuthenticated)
        {
            <text>
            setInterval(updateChatBadge, 30000);
            setInterval(updateInvitationBadge, 30000);
            updateChatBadge();
            updateInvitationBadge();
            </text>
        }
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>