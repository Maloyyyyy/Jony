@model JonyBalls3.Models.Calculator.CalculationRequest
@{
    ViewData["Title"] = "Калькулятор ремонта";
}

<div class="container py-5">
    <!-- HEADER -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold mb-2">
            <i class="fas fa-calculator me-2 text-gradient"></i>Калькулятор ремонта
        </h1>
        <p class="lead text-muted">Рассчитайте точную стоимость ремонта с учетом всех деталей</p>
    </div>

    <div class="row g-4">
        <!-- FORM SECTION -->
        <div class="col-lg-8">
            <div class="card-modern card">
                <div class="card-body p-4">
                    <form asp-action="Calculate" method="post" id="calculatorForm">
                        <!-- SECTION 1: BASIC PARAMETERS -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">
                                <i class="fas fa-home me-2" style="color: var(--primary);"></i>Основные параметры
                            </h5>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-600 mb-2">Площадь помещения (м²)</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-ruler"></i></span>
                                        <input asp-for="Area" type="number" min="1" max="1000" step="1" class="form-control" placeholder="50" />
                                    </div>
                                    <span asp-validation-for="Area" class="text-danger small"></span>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-600 mb-2">Количество комнат</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-door-open"></i></span>
                                        <input asp-for="RoomCount" type="number" min="1" max="20" step="1" class="form-control" placeholder="2" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- SECTION 2: REPAIR TYPE -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">
                                <i class="fas fa-hammer me-2" style="color: var(--primary);"></i>Тип и качество ремонта
                            </h5>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-600 mb-2">Тип ремонта</label>
                                    <select asp-for="RepairType" class="form-select">
                                        <option value="Косметический">Косметический</option>
                                        <option value="Капитальный">Капитальный</option>
                                        <option value="Дизайнерский">Дизайнерский</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-600 mb-2">Качество материалов</label>
                                    <select asp-for="MaterialQuality" class="form-select">
                                        <option value="Эконом">Эконом</option>
                                        <option value="Среднее" selected>Среднее</option>
                                        <option value="Премиум">Премиум</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- SECTION 3: WORK TYPES -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">
                                <i class="fas fa-list-check me-2" style="color: var(--primary);"></i>Виды работ
                            </h5>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludeWalls" class="form-check-input" id="walls" />
                                        <label for="walls" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-paint-roller me-2" style="color: var(--primary);"></i>Стены
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludeFloor" class="form-check-input" id="floor" />
                                        <label for="floor" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-square me-2" style="color: var(--success);"></i>Пол
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludeCeiling" class="form-check-input" id="ceiling" />
                                        <label for="ceiling" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-square me-2" style="color: var(--info);"></i>Потолок
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludeElectric" class="form-check-input" id="electric" />
                                        <label for="electric" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-bolt me-2" style="color: var(--warning);"></i>Электрика
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludePlumbing" class="form-check-input" id="plumbing" />
                                        <label for="plumbing" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-water me-2" style="color: var(--info);"></i>Сантехника
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <!-- SECTION 4: ADDITIONAL -->
                        <div class="mb-4">
                            <h5 class="fw-bold mb-3">
                                <i class="fas fa-plus-circle me-2" style="color: var(--primary);"></i>Дополнительные услуги
                            </h5>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludeDelivery" class="form-check-input" id="delivery" />
                                        <label for="delivery" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-truck me-2" style="color: var(--success);"></i>Доставка материалов
                                        </label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check p-3 rounded-2 glass-effect">
                                        <input asp-for="IncludeTools" class="form-check-input" id="tools" />
                                        <label for="tools" class="form-check-label fw-600 cursor-pointer">
                                            <i class="fas fa-wrench me-2" style="color: var(--warning);"></i>Аренда инструментов
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SUBMIT BUTTON -->
                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-gradient btn-lg">
                                <i class="fas fa-calculator me-2"></i>Рассчитать стоимость
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- SIDEBAR -->
        <div class="col-lg-4">
            <!-- PRICING GUIDE -->
            <div class="card-modern card mb-4">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-chart-bar me-2" style="color: var(--primary);"></i>Средние цены за м²
                    </h6>
                    <div class="d-flex flex-column gap-2">
                        <div class="p-3 rounded-2 bg-light">
                            <small class="text-muted d-block mb-1">Косметический</small>
                            <strong class="text-primary">5 000 - 8 000 ₽</strong>
                        </div>
                        <div class="p-3 rounded-2 bg-light">
                            <small class="text-muted d-block mb-1">Капитальный</small>
                            <strong class="text-success">10 000 - 15 000 ₽</strong>
                        </div>
                        <div class="p-3 rounded-2 bg-light">
                            <small class="text-muted d-block mb-1">Дизайнерский</small>
                            <strong class="text-info">15 000 - 25 000 ₽</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- TIPS -->
            <div class="card-modern card">
                <div class="card-body">
                    <h6 class="fw-bold mb-3">
                        <i class="fas fa-lightbulb me-2" style="color: var(--warning);"></i>Полезные советы
                    </h6>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success flex-shrink-0 mt-1"></i>
                            <small class="text-muted">Учитывайте сезонные скидки на материалы</small>
                        </div>
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success flex-shrink-0 mt-1"></i>
                            <small class="text-muted">Заказывайте материалы с запасом 10-15%</small>
                        </div>
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success flex-shrink-0 mt-1"></i>
                            <small class="text-muted">Получите несколько предложений от подрядчиков</small>
                        </div>
                        <div class="d-flex gap-2">
                            <i class="fas fa-check-circle text-success flex-shrink-0 mt-1"></i>
                            <small class="text-muted">Проверяйте сертификаты на материалы</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-600 {
        font-weight: 600;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .glass-effect {
        background: var(--glass-bg);
        border: 1px solid var(--glass-border);
        transition: all 0.3s ease;
    }

    .glass-effect:hover {
        background: rgba(255, 255, 255, 0.9);
        border-color: var(--primary);
    }

    .form-check-input:checked {
        background-color: var(--primary);
        border-color: var(--primary);
    }

    .form-check-input:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 0.25rem rgba(102, 126, 234, 0.25);
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
