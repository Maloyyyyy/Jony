@model JonyBalls3.Models.ProjectStage
<div class="container-fluid">
    <h4 class="fw-bold mb-1">@Model.Name</h4>
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <p class="text-muted mb-3">@Model.Description</p>
    }
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card border-0 rounded-3" style="background:#f8fafc;">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Бюджет этапа</small>
                    <div class="fw-bold text-primary">@Model.Budget.ToString("N0") ₽</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 rounded-3" style="background:#f8fafc;">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Потрачено</small>
                    <div class="fw-bold text-warning">@Model.Spent.ToString("N0") ₽</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 rounded-3" style="background:#f8fafc;">
                <div class="card-body py-2 px-3">
                    <small class="text-muted d-block">Прогресс</small>
                    <div class="fw-bold text-success">@Model.Progress%</div>
                </div>
            </div>
        </div>
    </div>
    <div class="progress mb-4" style="height: 12px; border-radius: 6px;">
        <div class="progress-bar bg-success" role="progressbar"
             style="width: @Model.Progress%; border-radius: 6px;">@Model.Progress%</div>
    </div>
    @if (Model.Photos != null && Model.Photos.Any())
    {
        <h6 class="fw-bold mb-3"><i class="fas fa-images me-2" style="color:#667eea;"></i>Фотографии этапа</h6>
        <div class="row g-3 mb-4">
            @foreach (var photo in Model.Photos)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card border-0 rounded-3 shadow-sm overflow-hidden h-100">
                        <a href="@photo.ImageUrl" target="_blank">
                            <img src="@photo.ImageUrl" class="card-img-top"
                                 alt="Фото этапа" style="height:140px;object-fit:cover;" />
                        </a>
                        @if (!string.IsNullOrEmpty(photo.Description))
                        {
                            <div class="card-body p-2">
                                <p class="card-text small text-muted mb-0">@photo.Description</p>
                            </div>
                        }
                        <div class="card-footer bg-white border-0 p-2">
                            <small class="text-muted">
                                <i class="fas fa-calendar-alt me-1"></i>
                                @photo.UploadedAt.ToString("dd.MM.yyyy")
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center text-muted py-3 mb-3">
            <i class="fas fa-camera fa-2x mb-2 d-block opacity-50"></i>
            Фотографий пока нет
        </div>
    }
    <div class="d-flex flex-wrap gap-2 mt-3">
        <button class="btn btn-sm btn-outline-primary update-progress"
                data-stage-id="@Model.Id" data-progress="@Model.Progress">
            <i class="fas fa-tasks me-1"></i>Обновить прогресс
        </button>
        <button class="btn btn-sm btn-outline-success add-expense-to-stage"
                data-stage-id="@Model.Id">
            <i class="fas fa-plus me-1"></i>Добавить расход
        </button>
        <button class="btn btn-sm btn-outline-info upload-stage-photo"
                data-stage-id="@Model.Id">
            <i class="fas fa-camera me-1"></i>Добавить фото
        </button>
    </div>
</div>
